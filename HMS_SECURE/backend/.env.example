NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/hms_master?retryWrites=true&w=majority
# Master database stores super-admin/platform data: users, hospitals, subscriptions, backups, etc.
MONGODB_DB_NAME=hms_master
JWT_SECRET=change_this_to_a_long_random_secret_before_production
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
FRONTEND_URL=http://localhost:5173
RATE_LIMIT_MAX=500
SEED_ADMIN_EMAIL=admin@hospital.com
SEED_ADMIN_PASSWORD=admin12345
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SaaS payment gateway foundation
SAAS_PAYMENT_GATEWAY=manual_gateway_ready
SAAS_PAYMENT_RETURN_URL=http://localhost:5173

# V26 Communication provider placeholders
EMAIL_PROVIDER=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMS_PROVIDER=
SMS_API_KEY=
WHATSAPP_PROVIDER=
WHATSAPP_TOKEN=

# V36 production hardening
API_PUBLIC_URL=http://localhost:5000
HEALTHCHECK_TIMEOUT_MS=8000
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
RESTORE_CONFIRMATION=
SENTRY_DSN=
UPTIME_MONITOR_URL=
TRUST_PROXY=1
CORS_EXTRA_ORIGINS=

# V44 tenant database isolation
# hybrid = new isolated tenant databases are created automatically while old shared DB tenants still work
TENANT_DATABASE_MODE=hybrid
TENANT_DB_ISOLATION=hybrid
TENANT_DB_PREFIX=hms_tenant
TENANT_CONNECTION_CACHE_MAX=100
TENANT_BACKUP_DIR=./backups/tenants
# Optional, if mongodump is not globally available on your server
MONGODUMP_BIN=mongodump
