NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/hms_db?retryWrites=true&w=majority
MONGODB_DB_NAME=hms_db
JWT_SECRET=change_this_to_a_long_random_secret_before_production
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
FRONTEND_URL=http://localhost:5173
RATE_LIMIT_MAX=500
SEED_ADMIN_EMAIL=admin@hospital.com
SEED_ADMIN_PASSWORD=admin12345
